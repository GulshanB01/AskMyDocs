POSTGRES_DB_NAME=askmydocs
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5433
POSTGRES_DB_USER=askmydocs
POSTGRES_DB_PASSWORD=askmydocs
# Railway may provide this instead of the separate POSTGRES_* variables.
DATABASE_URL=postgresql://askmydocs:askmydocs@localhost:5433/askmydocs

GROQ_API_KEY=your_groq_api_key
TOKEN_SECRET_KEY=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAILS=admin@example.com

ASKMYDOCS_API_URL=http://127.0.0.1:8000

LLM_INPUT_PRICE_PER_1M_TOKENS=0
LLM_OUTPUT_PRICE_PER_1M_TOKENS=0
